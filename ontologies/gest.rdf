    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#discourseFunctionalProperty -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#discourseFunctionalProperty">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Describes the role a gesture construction plays in discourse.</rdfs:comment>
        <rdfs:label xml:lang="en">Discourse-functional property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#ends -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#ends">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Slot"/>
        <rdfs:comment xml:lang="en">Describes the usage of a gesture construction with the specific verbal construction element whose realization coincides with the end of the gesture.</rdfs:comment>
        <rdfs:label xml:lang="en">ends with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#handedness -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#handedness">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Handedness"/>
        <rdfs:comment xml:lang="en">Refers to the hand or hands used in the execution of a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Handedness</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#handshape -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#handshape">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Refers to the configuration of the hand(s) during the execution of a gesture construction, specifying the physical arrangement of fingers and thumb.</rdfs:comment>
        <rdfs:label xml:lang="en">Handshape</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasForm -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasForm">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureConstruction"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureForm"/>
        <rdfs:comment xml:lang="en">Relates a gesture construction to its formal description.</rdfs:comment>
        <rdfs:label xml:lang="en">has form</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasGesture -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasGesture">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Construction"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage"/>
        <rdfs:comment xml:lang="en">Relates a multimodal construction to its usage of a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">has gesture</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasMeaning -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#hasMeaning">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureConstruction"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning"/>
        <rdfs:comment xml:lang="en">Relates a gesture construction to the description of its meaning and/or function.</rdfs:comment>
        <rdfs:label xml:lang="en">has meaning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#movement -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#movement">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Refers to the dynamic trajectory, direction, and manner of motion involved in a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Movement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#orientation -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#orientation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Refers to the direction in which the hand(s) are facing during a gesture construction, specifying the spatial alignment of the palm, fingers, or hand surface.</rdfs:comment>
        <rdfs:label xml:lang="en">Orientation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#position -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#position">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Refers to the spatial location of the hand(s) relative to the body during a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Position</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#pragmaticProperty -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#pragmaticProperty">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the functional role in discourse of a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Pragmatic property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#semanticProperty -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#semanticProperty">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the conceptual or referential content of the gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Semantic property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#starts -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#starts">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Slot"/>
        <rdfs:comment xml:lang="en">Describes the usage of a gesture construction with the specific verbal construction element whose realization coincides with the onset of the gesture.</rdfs:comment>
        <rdfs:label xml:lang="en">starts with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#timing -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#timing">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Refers to the temporal characteristics of a gesture construction, such as duration, ryththm or stroke.</rdfs:comment>
        <rdfs:label xml:lang="en">Timing</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#uses -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#uses">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage"/>
        <rdfs:range rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureConstruction"/>
        <rdfs:comment xml:lang="en">Relates the IRI for the gesture usage of the construction to the gesture construction(s) that are in use.</rdfs:comment>
        <rdfs:label xml:lang="en">uses the gesture construction</rdfs:label>
    </owl:ObjectProperty>
    


