    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureConstruction -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureConstruction">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Construction"/>
        <rdfs:comment xml:lang="en">A specific bodily gesture paired with a particular semantic or pragmatic function within a linguistic context.</rdfs:comment>
        <rdfs:label xml:lang="en">Gesture construction</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureForm -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureForm">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:comment xml:lang="en">The description of the full manifestation of a gesture (rather than its phases).</rdfs:comment>
        <rdfs:label xml:lang="en">Form of the gesture</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent">
        <rdfs:comment xml:lang="en">A class that subsumes both the overall form of a gestural construction and its individual temporal phases.</rdfs:comment>
        <rdfs:label xml:lang="en">Gesture formal component</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureMeaning">
        <rdfs:comment xml:lang="en">The description of the functional and interpretive significance of a gesture construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Meaning of the gesture</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureUsage">
        <rdfs:comment xml:lang="en">Denotes the non-verbal, gestural components associated with a linguistic construction.</rdfs:comment>
        <rdfs:label xml:lang="en">Gesture usage of the construction</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Handedness -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Handedness">
        <rdfs:label xml:lang="en">Handedness</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#LeftHand -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#LeftHand">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#OneHand"/>
        <rdfs:comment xml:lang="en">A gesture construction performed predominantly using the left hand, with the right hand either inactive or minimally involved.</rdfs:comment>
        <rdfs:label xml:lang="en">Left-Handed</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#OneHand -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#OneHand">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Handedness"/>
        <rdfs:comment xml:lang="en">A gesture construction performed predominantly using one hand, with the other hand either inactive or minimally involved.</rdfs:comment>
        <rdfs:label xml:lang="en">One-Handed</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Phase -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Phase">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#GestureFormalComponent"/>
        <rdfs:comment xml:lang="en">The formal description of a temporally distinct segment within the unfolding of a gestural construction.</rdfs:comment>
        <rdfs:seeAlso xml:lang="en">Phase</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#RightHand -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#RightHand">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#OneHand"/>
        <rdfs:comment xml:lang="en">A gesture construction performed predominantly using the right hand, with the left hand either inactive or minimally involved.</rdfs:comment>
        <rdfs:label xml:lang="en">Right-Handed</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#TwoHands -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#TwoHands">
        <rdfs:subClassOf rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#Handedness"/>
        <rdfs:comment xml:lang="en">A gesture construction performed using both hands simultaneously.</rdfs:comment>
        <rdfs:label xml:lang="en">Two-Handed</rdfs:label>
    </owl:Class>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Construction -->

    <owl:Class rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Construction"/>
    


