    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/evid#colloprofile -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/evid#colloprofile">
        <rdfs:domain rdf:resource="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#Slot"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Bag"/>
        <rdfs:comment xml:lang="en">Describes the colloprofile of a construction element. If the construction element is a slot that can be filled by various formal realizations, the colloprofile enumerates the (most frequent) realizations along with their respective frequencies.</rdfs:comment>
        <rdfs:label xml:lang="en">Colloprofile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/evid#filler -->

    <owl:ObjectProperty rdf:about="https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/evid#filler">
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A potential filler (i.e., formal realization) of a slot. A bag of fillers builds the colloprofile of the slot.</rdfs:comment>
        <rdfs:label xml:lang="en">Filler</rdfs:label>
    </owl:ObjectProperty>
    


