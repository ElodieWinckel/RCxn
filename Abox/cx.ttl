cx:gmh12C_PräfixverbkonstruktionTätigkeit_Ex_A a cx:Example ;
    cx:hasAnnotatedText "[ich]1 [durc]2 [ginc]3 in miner unſculde hercē mineſ in mitten huſeſ mineſ [TP h/55va,6]" ;
