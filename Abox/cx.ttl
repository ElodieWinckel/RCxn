cx:comePLUSnoisemannerofmovementVing_Ex_A a cx:Example ;
    cx:hasAnnotatedText "The back door burst open and [six-year-old Sally]1 [came]2 [running]3 excitedly [into the room]6 ." ;
    cx:hasText "The back door burst open and six-year-old Sally came running excitedly into the room ." .

cx:comePLUSnoisemannerofmovementVing_Ex_B a cx:Example ;
    cx:hasAnnotatedText "Then came thunder out of the east as [rank after rank of tanks]1 [came]2 [roaring]3 [past]5, plunged through the infantry and turned north for the kill ." ;
    cx:hasText "Then came thunder out of the east as rank after rank of tanks came roaring past, plunged through the infantry and turned north for the kill ." .

