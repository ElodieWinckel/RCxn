cx:deuWrSt20_sichNPADJADVvorAugenVP_1 a rcxn:SlotOptional ;
    cx:WordOrder "In most cases, NP precedes the prepositional phrase \"vor Augen\"." ;
    cx:colloprofile ( [ cx:frequency 39 ;
                cx:word "Ziel" ] [ cx:frequency 24 ;
                cx:word "Bild" ] [ cx:frequency 22 ;
                cx:word "Tod" ] [ cx:frequency 16 ;
                cx:word "Beispiel" ] [ cx:frequency 13 ;
                cx:word "Welt" ] [ cx:frequency 12 ;
                cx:word "Tatsache" ] [ cx:frequency 10 ;
                cx:word "Volk" ] ) ;
    cx:hasIS cx:Topic ;
    rcxn:hasSemanticProperty "The NP predominantly denotes abstract concepts, particularly those that are 1) subject to mental representation (Ziel, Bild, Beispiel), 2) abstract existential element or phenomenon (Welt, Tod, Tatsache), 3) collective entities." ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_1_Form ;
    rcxn:hasSyntacticFunction "Object" .

cx:deuWrSt20_sichNPADJADVvorAugenVP_1_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:deu_NounPhrase .

cx:deuWrSt20_sichNPADJADVvorAugenVP_2 a rcxn:SlotOptional ;
    cx:WordOrder "The adjectives mostly directly precedes the prepositional phrase \"vor Augen\"." ;
    cx:colloprofile ( [ cx:frequency 51 ;
                cx:word "deutlich" ] [ cx:frequency 47 ;
                cx:word "klar" ] [ cx:frequency 10 ;
                cx:word "anschaulich" ] [ cx:frequency 9 ;
                cx:word "eindringlich" ] [ cx:frequency 9 ;
                cx:word "lebendig" ] [ cx:frequency 9 ;
                cx:word "unmittelbar" ] [ cx:frequency 7 ;
                cx:word "lebhaft" ] ) ;
    rdfs:comment "The adjectives are also frequently modified by an adverb \"so\", forming adverbial phrases such as \"so deutlich, so klar\", etc. " ;
    rcxn:hasSemanticProperty "The adjectives share the semantic property of describing vividness or clarity." ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_2_Form .

cx:deuWrSt20_sichNPADJADVvorAugenVP_2_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:deu_Adjective .

cx:deuWrSt20_sichNPADJADVvorAugenVP_3 a rcxn:SlotOptional ;
    cx:WordOrder "The adverbs typically appear directly before the prepositional phrase \"vor Augen\"." ;
    cx:colloprofile ( [ cx:frequency 42 ;
                cx:word "immer" ] [ cx:frequency 32 ;
                cx:word "wieder" ] [ cx:frequency 27 ;
                cx:word "stets" ] [ cx:frequency 25 ;
                cx:word "noch" ] [ cx:frequency 9 ;
                cx:word "täglich" ] ) ;
    rcxn:hasSemanticProperty "The adverbs share a semantic property of expressing recurrence or regularity." ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_3_Form .

cx:deuWrSt20_sichNPADJADVvorAugenVP_3_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:deu_Adverb .

cx:deuWrSt20_sichNPADJADVvorAugenVP_4 a rcxn:SlotObligatory ;
    cx:WordOrder "The preposition \"vor\" appears in direct syntactic proximity to the noun \"Augen\", forming a fixed prepositional phrase. " ;
    cx:hasIS cx:Background,
        cx:Comment ;
    cx:hasTranslation "in front of " ;
    olia:hasSemanticRole olia:LocationRole ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_4_Form ;
    rcxn:hasSyntacticFunction "Head of a prepositional phrase" .

cx:deuWrSt20_sichNPADJADVvorAugenVP_4_Form a rcxn:SlotForm ;
    rcxn:hasStem cx:deu_vor .

cx:deuWrSt20_sichNPADJADVvorAugenVP_5 a rcxn:SlotObligatory ;
    cx:WordOrder "The noun always directly follows the preposition \"vor\"." ;
    cx:hasIS cx:Background,
        cx:Comment ;
    cx:hasTranslation "eyes" ;
    rcxn:hasSemanticProperty "The noun does not refer to the literal body part but rather conveys a metaphorically extended meaning, representing perception, awareness or mental visualization." ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_5_Form ;
    rcxn:hasSyntacticFunction "Prepositional complement" .

cx:deuWrSt20_sichNPADJADVvorAugenVP_5_Form a rcxn:SlotForm ;
    rcxn:hasSurfaceForm "Augen" ;
    rcxn:hasSyntacticForm cx:deu_Noun .

cx:deuWrSt20_sichNPADJADVvorAugenVP_6 a rcxn:SlotOptional ;
    cx:WordOrder "The position of the verb within the construction is relatively flexible." ;
    cx:colloprofile ( [ cx:frequency 225 ;
                cx:word "führen" ] [ cx:frequency 143 ;
                cx:word "halten" ] [ cx:frequency 129 ;
                cx:word "haben" ] [ cx:frequency 25 ;
                cx:word "stellen" ] [ cx:frequency 15 ;
                cx:word "stehen" ] ) ;
    cx:hasIS cx:Comment ;
    rdfs:comment "When the verb führen or halten occur, the reflexive pronoun \"sich\" is obligatory present (Element 1)." ;
    rcxn:hasSemanticProperty "Though these verbs are highly polysemous, they either relate to the positioning of something in space, either actively (führen, stellen) or passively (stehen), or imply control or possession (halten, haben, führen)" ;
    rcxn:hasSlotForm cx:deuWrSt20_sichNPADJADVvorAugenVP_6_Form .

cx:deuWrSt20_sichNPADJADVvorAugenVP_6_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:deu_Verb .

