cx:gmh12C_PräfixverbkonstruktionHandlung_Ex_A a cx:Example ;
    cx:hasAnnotatedText "[ſi]1 [durh]2 [hiwen]3 [daz wal]4 " ;
    cx:hasGlosses "they through punched the battlefield" ;
    cx:hasText "ſi durh hiwen daz wal " ;
    cx:hasTranslation "'they punched their way through the battlefield'" ;
    cx:hasTransliteration "si durh hiwen daz wal" ;
    rdfs:comment "Source: Jüngere Judith: 0a,415; see https://www.linguistics.rub.de/rem/pub/texts//M119_dipl.pdf" .

cx:gmh12C_PräfixverbkonstruktionHandlung_Ex_B a cx:Example ;
    cx:hasAnnotatedText "[ſi]1 giengen ûz unt [durh]2 [giengen]3 [div caſtel]4 brediginde vnt heilinde allen thalbin " ;
    cx:hasGlosses "they went out and through went the castle preaching and healing to all directions" ;
    cx:hasText "ſi giengen ûz unt durh giengen div caſtel brediginde vnt heilinde allen thalbin " ;
    cx:hasTranslation "'they went out and went through the castle, preaching and healing to every side'" ;
    cx:hasTransliteration "si giengen uz und durh giengen div castel brediginde unt heilinde allen thalbin" ;
    rdfs:comment "Source: Wien-Münchner Evangelienübersetzung: 48ba,14; see https://www.linguistics.rub.de/rem/pub/texts//M067_dipl.pdf" .

cx:gmh12C_PräfixverbkonstruktionHandlung_Ex_C a cx:Example ;
    cx:hasAnnotatedText "got uir lazin hat in. [durch]2[ethint]3 [in]4 un̄ begrifet in" ;
    cx:hasGlosses "god left him. chase him and get him" ;
    cx:hasText "got uir lazin hat in. durchethint in un̄ begrifet in" ;
    cx:hasTranslation "'God left him. Chase him down and get him!'" ;
    rdfs:comment "Source: Trierer Interlinearversion zum Psalter: 28va,9; see https://www.linguistics.rub.de/rem/pub/texts//M188_dipl.pdf" .

