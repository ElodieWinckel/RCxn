    rdf_ns:_1 cx:deu_SuperlativADJest_1 ;
    rdf_ns:_2 cx:deu_SuperlativADJest_2 .

cx:deu_SuperlativADJst_ADJ_1 a rcxn:SlotObligatory ;
    compcon:hasCompCon compcon:inf_admodification ;
    rcxn:hasSlots cx:deu_SuperlativADJst_ADJ_1_slots .

