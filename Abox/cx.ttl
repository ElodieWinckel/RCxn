cx:engLME_Argumentstructureconstruction a rcxn:Construction ;
    rdfs:comment """The main data includes 2000 sentences that are generated by GPT-4, which is a text file.\r\r
The extension data includes a representation of these data in LLM and brain, \r\r
Representation in LLMs are matrixes including hidden layer activity and attention factor.\r\r
The representation in the brain includes EEG recordings from 10 participants while listening to 200 of these sentences.\r\r
Both are matrixes in the format of NumPy arrays but can be converted to any supporting format.\r\r
\r\r
This is a similar publicly available dataset: https://github.com/SPOClab-ca/neural-reality-constructions\r\r
""" ;
    lg:partOfLanguage lg:eng ;
    links:inheritedBy cx:engLME_Ditransitiveconstruction,
        cx:engLME_Resultativeconstruction,
        cx:engLME_Transitiveconstruction,
        cx:eng_CauseMotionconstruction ;
    rcxn:hasConstructionMeaning cx:engLME_Argumentstructureconstruction_Meaning ;
    rcxn:hasMetadata cx:engLME_Argumentstructureconstruction_MD ;
    rcxn:hasSlots cx:engLME_Argumentstructureconstruction_slots ;
    rcxn:hasTitle "Argument structure construction" .

