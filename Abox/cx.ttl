    rcxn:hasSyntacticFunction "Verb" .

cx:arzCai_Ditransitiveconstruction_3 a rcxn:SlotObligatory ;
    cx:WordOrder "After Element 2, before or after Element 4" ;
    cx:hasIndex cx:arzCai_Ditransitiveconstruction_3_Index ;
    olia:hasSemanticRole olia:RecipientRole ;
    rdfs:comment "Obligatorily marked by the preposition/dative marker li- if the theme is pronominal, otherwise marking is optional. " ;
