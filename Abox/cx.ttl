cx:arzCai_Ditransitiveconstruction_Ex_A a cx:Example ;
    cx:hasAnnotatedText "[Leyla]1 [iddit]2 [(li-)Ḫālid]3 [il-kitāb]4." ;
    cx:hasGlosses "Leyla give.3SGF.PERF (to-)Ḫālid the-book" ;
    cx:hasText "Leyla iddit (li-)Ḫālid il-kitāb." ;
    cx:hasTranslation "Leyla gave Ḫālid the book." .

cx:arzCai_Ditransitiveconstruction_Ex_B a cx:Example ;
    cx:hasAnnotatedText "[warrēt]2 [(li-)s-suwwāḥ]3 [il-matḥaf]4." ;
    cx:hasGlosses "show.1SG.PERF (to-)the-tourists the-museum" ;
    cx:hasText "warrēt (li-)s-suwwāḥ il-matḥaf" ;
    cx:hasTranslation "I showed the tourists the museum." .

cx:arzCai_Ditransitiveconstruction_Ex_C a cx:Example ;
    cx:hasAnnotatedText "[fahhimti]2-[hā]4-[l-ha]3?" ;
    cx:hasGlosses "explain.2SGF.PERF-OBJ.3SGF-DAT-OBJ.3SGF" ;
    cx:hasText "fahhimti-hā-l-ha?" ;
    cx:hasTranslation "Have you explained it to her?" .

