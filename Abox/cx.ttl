cx:arzCai_Ditransitiveconstruction_2 a rcxn:SlotObligatory ;
    cx:WordOrder "After Element 1, before Elements 3 and 4" ;
    rdfs:comment "colloprofile: idda; ʿallim; nāwil; massik; sallif; labbis; sallim; ḥammil; darris; šammim; fahhim; ḥaffaẓ; nassa; ballaġ; saʾal; fahhim; malla; warra; ḫassaṛ; ġaṛṛam; ʾallaʿ" ;
    rcxn:hasSemanticProperty "Verbs of the four following groups: \"to give\", \"to provide s.o. with sth.\", \"to tell\", \"to withdraw\"" ;
    rcxn:hasSyntacticFunction "Verb" .

cx:arzCai_Ditransitiveconstruction_3 a rcxn:SlotObligatory ;
    cx:WordOrder "After Element 2, before or after Element 4" ;
    cx:hasIndex cx:arzCai_Ditransitiveconstruction_3_Index ;
    olia:hasSemanticRole olia:RecipientRole ;
    rdfs:comment "Obligatorily marked by the preposition/dative marker li- if the theme is pronominal, otherwise marking is optional. " ;
