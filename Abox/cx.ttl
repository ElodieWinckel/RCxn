cx:arzCai_Ditransitiveconstruction_2 a rcxn:SlotObligatory ;
    cx:WordOrder "After Element 1, before Elements 3 and 4" ;
    rdfs:comment "colloprofile: idda; ʿallim; nāwil; massik; sallif; labbis; sallim; ḥammil; darris; šammim; fahhim; ḥaffaẓ; nassa; ballaġ; saʾal; fahhim; malla; warra; ḫassaṛ; ġaṛṛam; ʾallaʿ" ;
