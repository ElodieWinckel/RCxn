    rcxn:hasSlotForm cx:engUsSpo_Hadituptoherewith_3_Form ;
    rcxn:hasSyntacticFunction "Oblique complement" .

cx:engUsSpo_Hadituptoherewith_3_Form a rcxn:SlotForm ;
