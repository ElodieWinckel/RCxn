membr:Project_Iabdounane_F250218 rsrch:basedOn cx:engUsSpo_Hadituptoherewith .

cx:engUsSpo_Hadituptoherewith_1 a rcxn:SlotObligatory ;
    olia:hasSemanticRole olia:ExperiencerRole ;
    rcxn:hasSlotForm cx:engUsSpo_Hadituptoherewith_1_Form ;
    rcxn:hasSyntacticFunction "Subject" .

cx:engUsSpo_Hadituptoherewith_1_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_NounPhrase .

cx:engUsSpo_Hadituptoherewith_2 a rcxn:SlotObligatory ;
    rcxn:hasOtherSemanticContribution "Enough" ;
    rcxn:hasSlotForm cx:engUsSpo_Hadituptoherewith_2_Form ;
    rcxn:hasSyntacticFunction "Predicator" .

cx:engUsSpo_Hadituptoherewith_2_Form a rcxn:SlotForm ;
