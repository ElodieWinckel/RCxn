cx:engUsSpo_Hadituptoherewith a rcxn:Construction ;
    cx:hasExample cx:engUsSpo_Hadituptoherewith_Ex_A ;
    RDFS:comment "The Throat Cut Gesture Positioned at the Head Level" ;
    lg:partOfLanguage lg:engUsSpo ;
    rcxn:hasConstructionMeaning cx:engUsSpo_Hadituptoherewith_Meaning ;
    rcxn:hasMetadata cx:engUsSpo_Hadituptoherewith_MD ;
    rcxn:hasSlots cx:engUsSpo_Hadituptoherewith_slots ;
    rcxn:hasTitle "Had it up to here with" ;
    gest:hasGesture cx:engUsSpo_Hadituptoherewith_Gest ;
    links:inheritsFrom cx:engUsSpo_Hadituptoherewithmesoconstruction .

cx:engUsSpo_Hadituptoherewith_Gest a gest:GestureUsage ;
