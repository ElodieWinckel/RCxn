    dcterm:created "2026-07-07"^^xsd:date ;
    rcxn:annotator membr:Iabdounane .

cx:engUsSpo_Hadituptoherewith_Meaning a rcxn:ConstructionMeaning ;
    rcxn:hasMeaning "[An experiencer]1 has reached their maximum tolerance level of [a negative stimulus]3 and cannot take more of it." .

cx:engUsSpo_Hadituptoherewith_slots a rdf:Seq ;
