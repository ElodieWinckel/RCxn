membr:Project_Lee rsrch:hasResearchQuestion membr:Project_Lee_241202 .

membr:Project_Lee_241202 a rsrch:Project ;
    rsrch:projectName "Prepositional constructions - a corpuslinguistic study on collocation patterns and construction networks" ;
    rsrch:hasFindings membr:Project_Lee_241202_F250218 .

membr:Project_Lee_241202_F250218 a rsrch:Finding ;
    rdfs:label "Grammatically fixed with zero-realization, the \"vor-Augen construction\" displays a distinct collocational pattern closely tied to its meaning and contextual usage." ;
    rsrch:basedOn cx:deuWrSt20_sichNPADJADVvorAugenVP_MD .

cx:deu_vor a rcxn:Construction ;
    rcxn:hasTitle "vor" ;
    rcxn:hasConstructionMeaning cx:deu_vor_Meaning ;
    lg:partOfLanguage lg:deu.

cx:deu_vor_Meaning a rcxn:ConstructionMeaning ;
    rcxn:hasMeaning "in front of" .