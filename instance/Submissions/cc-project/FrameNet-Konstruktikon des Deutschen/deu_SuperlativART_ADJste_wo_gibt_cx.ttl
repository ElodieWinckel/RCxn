cx:deu_SuperlativART_ADJste_wo_gibt a rcxn:Construction ;
    cx:hasExample cx:deu_SuperlativART_ADJste_wo_gibt_Ex_A,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_B,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_C,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_D,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_E,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_F,
        cx:deu_SuperlativART_ADJste_wo_gibt_Ex_G ;
    RDFS:comment """Original entry by Benjamin Fischer: „Superlativ:ART_ADJ-ste_wo_gibt“, in: FrameNet-Konstruktikon des Deutschen, https://framenet-constructicon.hhu.de/constructicon/construction?id=2640, abgerufen am 22.05.2026.""" ,
        """Die Konstruktion wird in der Literatur bzw. in Grammatiken auch thematisiert unter: "2. Steigerung", "Elativ", "Komparation" & "Relativer Superlativ".""" ,
        """Die Konstruktion Superlativ:ART_ADJ-ste_wo_gibt ähnelt der Konstruktion Superlativ:ART_ADJ-(e)st in vielen Aspekten, unterscheidet sich von ihr aber insbesondere durch die zusätzlich verstärkende Wortreihung wo gibt und die informellere Natur.""" ;
    lg:partOfLanguage lg:deu ;
    links:inheritsFrom cx:deu_SuperlativART_ADJest ;
