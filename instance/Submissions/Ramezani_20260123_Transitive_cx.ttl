@prefix RDFS: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix cx: <http://example.org/cx/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterm: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lg: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/lg#> .
@prefix links: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/links-1.1#> .
@prefix membr: <https://bdlweb.phil.uni-erlangen.de/RCxn/Abox/membr#> .
@prefix rcxn: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rsrch: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rsrch#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cx:engLME_Transitiveconstruction rcxn:hasConstructionMeaning cx:engLME_Transitiveconstruction_Meaning ;
    rcxn:hasSlots cx:engLME_Transitiveconstruction_slots ;
    cx:hasExample cx:engLME_Transitiveconstruction_Ex_A .

cx:engLME_Transitiveconstruction_slots a rdf:Seq ;
    rdf:_1 cx:engLME_Transitiveconstruction_1 ;
    rdf:_2 cx:engLME_Transitiveconstruction_2 ;
    rdf:_3 cx:engLME_Transitiveconstruction_3 .

cx:engLME_Transitiveconstruction_1 a rcxn:SlotObligatory ;
    rcxn:hasSyntacticFunction "Subject" .

cx:engLME_Transitiveconstruction_2 a rcxn:SlotObligatory .

cx:engLME_Transitiveconstruction_2_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_Verb .

cx:engLME_Transitiveconstruction_3 a rcxn:SlotObligatory ;
    rcxn:hasSyntacticFunction "Object" .

cx:engLME_Transitiveconstruction_Meaning a rcxn:ConstructionMeaning ;
    rcxn:hasMeaning """A [subject]1 performs [an action]2 on [a direct object]3.""" .

cx:engLME_Transitiveconstruction_Ex_A a cx:Example ;
    cx:hasText "The baker baked a cake." ;
    cx:hasAnnotatedText "[The baker]1 [baked]2 [a cake]3." .

membr:Project_Ramezani_250214_F250218 rsrch:basedOn cx:engLME_Transitiveconstruction .

