cx:engLME_Burnonesbridgesconstruction_Ex_A a cx:Example ;
    cx:hasAnnotatedText "[He]1 [had burned]2 [his]3 [bridges]4 in Hollywood and took off for the seclusion of Taos to hide away..." ;
