cx:engLME_Burnonesbridgesconstruction_Ex_B a cx:Example ;
    cx:hasAnnotatedText "[I]1 [had]2, quite deliberately, [burned]2 [my]3 [bridges]4 -- there was no returning to the closet for me." ;
    cx:hasText "I had, quite deliberately, burned my bridges -- there was no returning to the closet for me." .

