@prefix RDFS: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix casa: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/casa#> .
@prefix cx: <http://example.org/cx/> .
@prefix dcterm: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lg: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/lg#> .
@prefix links: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/links-1.1#> .
@prefix membr: <https://bdlweb.phil.uni-erlangen.de/RCxn/Abox/membr#> .
@prefix rcxn: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rsrch: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rsrch#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cx:Active3ArgumentStructureConstruction a rcxn:Construction ;
    links:inheritedBy cx:engLME_AttributeConstructionAttrAdj ;
    rcxn:hasMetadata cx:Active3ArgumentStructureConstruction_MD ;
    rcxn:hasTitle "Active 3 Argument Structure Construction" .

cx:Active3ArgumentStructureConstruction_MD a rcxn:Metadata ;
    rcxn:annotator membr:Winckel ;
    dcterm:created "2026-01-13"^^xsd:date .

cx:engLME_Resultativeconstruction links:sameFormDifferentFunction cx:engLME_AttributeConstructionAttrAdj .

cx:eng_AdjectivePhrase links:elementOf cx:engLME_AttributeConstructionAttrAdj .

cx:engLME_AttributeConstructionAttrAdj_1 a rcxn:SlotOptional ;
    rcxn:hasOtherSemanticContribution "Æffector" ;
    rcxn:hasSlotForm cx:engLME_AttributeConstructionAttrAdj_1_Form ;
    rcxn:hasSyntacticFunction "potential subject" ;
    casa:hasCasaSyntacticFunction "potential subject" .

cx:engLME_AttributeConstructionAttrAdj_1_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_NounPhrase .

cx:engLME_AttributeConstructionAttrAdj_2 a rcxn:SlotObligatory ;
    RDFS:comment "colloprofile: account  assume  beat  believe  consider  discover  dream  find  guarantee  judge  label  lay  mark  pass  present  show  think  worry  " ,
        "Source for collo-profile: Valency Dictionary of English, Patternbank" ,
        "Borderline cases: buy sell (something cheap) ";
    rcxn:hasSlotForm cx:engLME_AttributeConstructionAttrAdj_2_Form .

cx:engLME_AttributeConstructionAttrAdj_2_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_Verb .

cx:engLME_AttributeConstructionAttrAdj_3 a rcxn:SlotObligatory ;
    rcxn:hasOtherSemanticContribution "Æffected-Attributee" ;
    rcxn:hasSlotForm cx:engLME_AttributeConstructionAttrAdj_3_Form ;
    rcxn:hasSyntacticFunction "direct object" ;
    casa:hasCasaSyntacticFunction "Obj" .

cx:engLME_AttributeConstructionAttrAdj_3_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_NounPhrase .

cx:engLME_AttributeConstructionAttrAdj_4 a rcxn:SlotObligatory ;
    rcxn:hasOtherSemanticContribution "Attribute" ;
    rcxn:hasSlotForm cx:engLME_AttributeConstructionAttrAdj_4_Form ;
    rcxn:hasSyntacticFunction "object complement" ;
    casa:hasCasaSyntacticFunction "Attr" .

cx:engLME_AttributeConstructionAttrAdj_4_Form a rcxn:SlotForm ;
    rcxn:hasSyntacticForm cx:eng_AdjectivePhrase .

cx:engLME_AttributeConstructionAttrAdj_Ex_A a cx:Example ;
    cx:hasAnnotatedText "[She]1 [called]2 [the idea]3 [stupid]4." ;
    cx:hasText "She called the idea stupid." .

cx:engLME_AttributeConstructionAttrAdj_MD a rcxn:Metadata ;
    cx:hasSources cx:engLME_AttributeConstructionAttrAdj_Sources ;
    rcxn:annotator membr:Winckel ,
         membr:Garibyan ;
    dcterm:created "2026-01-13"^^xsd:date .

cx:engLME_AttributeConstructionAttrAdj_Meaning a rcxn:ConstructionMeaning ;
    rcxn:hasMeaning "An [ÆFFECTOR]1 assigns an [ATTRIBUTE]4 to an [ATTRIBUTEE]3." .

cx:engLME_AttributeConstructionAttrAdj_Sources a cx:Collection ;
    RDFS:seeAlso <https://constructicon.de/constructions/23> .

cx:engLME_AttributeConstructionAttrAdj_slots a rdf:Seq ;
    rdf:_1 cx:engLME_AttributeConstructionAttrAdj_1 ;
    rdf:_2 cx:engLME_AttributeConstructionAttrAdj_2 ;
    rdf:_3 cx:engLME_AttributeConstructionAttrAdj_3 ;
    rdf:_4 cx:engLME_AttributeConstructionAttrAdj_4 .

cx:eng_Verb links:elementOf cx:engLME_AttributeConstructionAttrAdj .

cx:eng_NounPhrase links:elementOf cx:engLME_AttributeConstructionAttrAdj .

cx:engLME_AttributeConstructionAttrAdj a rcxn:Construction ;
    cx:hasExample cx:engLME_AttributeConstructionAttrAdj_Ex_A ;
    lg:partOfLanguage lg:eng ;
    links:inheritsFrom cx:Active3ArgumentStructureConstruction ;
    links:sameFormDifferentFunction cx:engLME_Resultativeconstruction ;
    rcxn:hasConstructionMeaning cx:engLME_AttributeConstructionAttrAdj_Meaning ;
    rcxn:hasMetadata cx:engLME_AttributeConstructionAttrAdj_MD ;
    rcxn:hasSlots cx:engLME_AttributeConstructionAttrAdj_slots ;
    rcxn:hasTitle "Attribute Construction (Attr: Adj)" .

membr:Project_Winckel_2601131454_F2601131454 rsrch:basedOn cx:engLME_AttributeConstructionAttrAdj .