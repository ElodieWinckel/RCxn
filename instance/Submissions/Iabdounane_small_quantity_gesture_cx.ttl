cx:eng_ThisclosetoVingconstruction cx:usesGesture cx:SmallQuantityGestureConstruction .

cx:SmallQuantityGestureConstruction a gest:GestureConstruction ;
    cx:endsOnSlot cx:eng_ThisclosetoVingconstruction_6 ;
    cx:hasForm cx:SmallQuantityGestureConstruction_Form ;
    gest:hasPhases "1" ;
    cx:stratsOnSlot cx:eng_ThisclosetoVingconstruction_1 ;
    lg:partOfLanguage lg:eng ;
    rcxn:hasMeaning cx:SmallQuantityGestureConstruction_Meaning ;
    rcxn:hasTitle "Small Quantity Gesture Construction" ;
    rcxn:hasMetadata cx:SmallQuantityGestureConstruction_MD .

cx:SmallQuantityGestureConstruction_Form cx:timing "Usually for the entire duration of the co-occurring verbal construction." ;
    cx:handedness cx:OneHand ;
    cx:handshape "Middle, right, and little fingers retracted toward the palm.",
        "Thumb and index extended or crooked and parallel to each other." ;
    cx:movement "Static hold or beat." ;
    cx:orientation "Palm Lateral." ;
    cx:position "Central space or at face level." .

cx:SmallQuantityGestureConstruction_Meaning cx:pragmaticProperty "Affective/evaluative framing.",
        "Foregrounding the small quantity of the referent." ;
    cx:semanticProperty "Small quantity." .

cx:SmallQuantityGestureConstruction_MD a rcxn:Metadata ;
