cx:eng_ChefskissGesturalConstruction a gest:GestureConstruction ;
    gest:hasForm cx:eng_ChefskissGesturalConstruction_Form ;
    gest:hasMeaning cx:eng_ChefskissGesturalConstruction_Meaning ;
    lg:partOfLanguage lg:eng ;
    rcxn:hasTitle "Chef’s Kiss as a Gestural Construction" ;
    rcxn:hasMetadata cx:eng_ChefskissGesturalConstruction_MD .

cx:eng_ChefskissGesturalConstruction_Form a gest:GestureForm ;
    a rdf:Seq ;
    gest:timing "Usually no longer than 1 second." ;
    gest:handedness gest:OneHand ;
    gest:sound "Kissing sound" ;
    gest:position "Central space at mouth level." ;
    rdf:_1 cx:eng_ChefskissGesturalConstruction_1 ;
    rdf:_2 cx:eng_ChefskissGesturalConstruction_2 ;
    rdf:_3 cx:eng_ChefskissGesturalConstruction_3 .

cx:eng_ChefskissGesturalConstruction_1  a gest:Phase ;
    gest:handshape "All fingers are extended, touching at their tips." ;
    gest:movement "Bringing fingers together." ;
    gest:orientation "Palm is lateral." , "Fingers oriented upwards." .

cx:eng_ChefskissGesturalConstruction_2  a gest:Phase ;
    gest:handshape "All fingers are extended, touching at their tips." ;
    gest:movement "Kissing the tips of the fingers." ;
    gest:orientation "Palm is vertical." , "Fingers oriented towards the speaker’s mouth." .

cx:eng_ChefskissGesturalConstruction_3  a gest:Phase ;
    gest:handshape "All fingers are extended, and their tips are brought away from each other." ;
    gest:movement "Releasing the fingers away from mouth." ;
    gest:orientation "Palm is lateral." , "Fingers oriented upwards." .

cx:eng_ChefskissGesturalConstruction_Meaning a gest:GestureMeaning ;
    gest:semanticProperty "Something or someone is perfect or excellent." .

cx:eng_ChefskissGesturalConstruction_MD a rcxn:Metadata ;
    cx:annotator membr:Iabdounane ;
    dcterm:created "2026-07-07"^^xsd:date .

