@prefix cx: <http://example.org/cx/> .
@prefix lg: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/lg#> .
@prefix rcxn: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/rcxn#> .
@prefix gest: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/gest#> .

cx:eng_ThroatCutGesture a gest:GestureConstruction ;
    gest:hasForm cx:eng_ThroatCutGesture_Form ;
    gest:hasPhases "1" ;
    lg:partOfLanguage lg:eng ;
    rcxn:hasMeaning cx:eng_ThroatCutGesture_Meaning ;
    rcxn:hasTitle "Throat Cut Gesture Construction" .

cx:eng_ThroatCutGesture_Form gest:timing "Context-dependent." ;
    gest:handedness gest:OneHand ;
    gest:handshape "The index, middle, ring and little fingers are fully extended and together.",
        "The thumb is either tucked or relaxed alongside the hand." ;
    gest:movement "Horizontal side-to-side motion." ;
    gest:orientation "Palm is vertical." , "Fingers oriented toward the speaker's neck." ;
    gest:position "At the neck level." .

cx:eng_ThroatCutGesture_Meaning gest:semanticProperty "Putting an end to something" ;
    gest:pragmaticProperty "Directive, request, warning, or, framing." ;
    gest:discourseFunctionalProperty "Turn management" .

