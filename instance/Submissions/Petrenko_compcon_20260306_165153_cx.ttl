        compcon:cxn_modifier,
        compcon:cxn_quantifier-term,
        compcon:inf_modification .

cx:engLME_MoreThanComparisonConstructiontype2_2 compcon:hasCompCon compcon:sem_comparee,
        compcon:sem_entity,
        compcon:sem_gradable-predicative-scale,
        compcon:sem_object-concept .

cx:engLME_MoreThanComparisonConstructiontype2_3 compcon:hasCompCon compcon:str_conjunction .

cx:engLME_MoreThanComparisonConstructiontype2_4 compcon:hasCompCon compcon:inf_reference,
        compcon:sem_standard .

