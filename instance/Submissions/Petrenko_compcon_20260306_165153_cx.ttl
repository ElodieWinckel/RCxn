@prefix compcon: <https://bdlweb.phil.uni-erlangen.de/RCxn/ontologies/compcon#> .
@prefix cx: <http://example.org/cx/> .

cx:engLME_MoreThanComparisonConstructiontype2 compcon:hasCompCon compcon:cxn_comparative-construction,
        compcon:sem_comparative-relation,
        compcon:sem_degree,
        compcon:sem_gradable-predicative-scale,
        compcon:str_particle-comparative .

